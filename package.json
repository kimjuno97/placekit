{
  "name": "placekit",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/placekit.cjs",
  "module": "./dist/placekit.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/placekit.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/placekit.js",
      "require": "./dist/placekit.cjs"
    },
    "./style.css": "./dist/placekit.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "lint": "oxlint",
    "prepack": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.21.0",
    "@vanilla-extract/recipes": "^0.5.7"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "mockdate": "^3.0.5",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "oxlint": "^1.69.0",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
