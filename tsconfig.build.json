{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.build.tsbuildinfo"
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx"
  ],
  "include": ["src/index.ts", "src/components/**/*.ts", "src/components/**/*.tsx"]
}
